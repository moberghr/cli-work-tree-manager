{
  "name": "work-tree",
  "version": "1.3.0",
  "description": "Cross-platform Git worktree manager for multiple repositories",
  "type": "module",
  "bin": {
    "work": "./dist/bin.js",
    "wd": "./dist/wd-bin.js"
  },
  "scripts": {
    "build": "npm run build:server && npm run build:web",
    "build:server": "tsup",
    "build:web": "vite build",
    "typecheck": "tsc --noEmit && tsc --noEmit -p src/web/tsconfig.json",
    "dev": "tsx src/bin.ts",
    "dev:web": "vite",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "git",
    "worktree",
    "cli"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@types/diff": "^7.0.2",
    "@types/proper-lockfile": "^4.1.4",
    "@xterm/headless": "^6.0.0",
    "chalk": "^5.4.1",
    "chokidar": "^5.0.0",
    "cross-spawn": "^7.0.6",
    "diff": "^9.0.0",
    "dompurify": "^3.4.7",
    "glob": "^11.0.1",
    "highlight.js": "^11.11.1",
    "ink": "^6.8.0",
    "inquirer": "^12.3.2",
    "marked": "^18.0.4",
    "node-pty": "^1.1.0",
    "proper-lockfile": "^4.1.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.6",
    "yargs": "^17.7.2"
  },
  "devDependencies": {
    "@types/cross-spawn": "^6.0.6",
    "@types/dompurify": "^3.0.5",
    "@types/node": "^22.13.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/yargs": "^17.0.33",
    "@vitejs/plugin-react": "^4.7.0",
    "tsup": "^8.3.6",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vite": "^7.3.3",
    "vitest": "^3.0.5"
  }
}
